[Unit]
Description=ChatTool web chat service
After=network.target

[Service]
Type=simple
User=YOUR_USER
WorkingDirectory=/opt/chattool
EnvironmentFile=/opt/chattool/.env
ExecStart=/opt/chattool/.venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 13579
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target

